{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "ConnectionStrings": {
    "DefaultConnection": "your sql server connection string - store in user secrets"
  },

  "Ai": {
    "ApiKey": "store-in-user-secrets",
    "Model": "gpt-4o-mini"
  },

  "Crypto": {
    "PassPhrase": "a really long pass phrase - store in user secrets"
  },

  "Jwt": {
    "SecretKey": "your jwt secret key",
    "Issuer": "your jwt issuer",
    "Audience": "your jwt audience",
    "TokenExpiryInMinutes": 30,
    "RefreshTokenExpiryInMinutes": 60
  },

  "PasswordPolicy": {
    "MinPasswordLength": 15,
    "RequireLowercase": true,
    "RequireUppercase": true,
    "RequireDigit": true,
    "RequireSpecialCharacter": true
  },

  "Caching": {
    "DomainCacheDurationInMinutes": 60
  },

  "FileUpload": {
    "RootPath": "uploads",
    "RequestPath": "/uploads"
  },

  "Email": {
    "Host": "your smtp host - store in user secrets",
    "Port": 587,
    "EnableSsl": true,
    "Username": "your smtp username - store in user secrets",
    "Password": "your smtp password - store in user secrets",
    "FromAddress": "noreply@yourdomain.com",
    "FromName": "ABCD"
  }
}