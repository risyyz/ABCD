{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  
  "ConnectionStrings": {
    "DefaultConnection": "your sql server connection string - store in user secrets"
  },

  "Crypto": {
    "PassPhrase": "a really long pass phrase - store in user secrets"
  },

  "Jwt": {
    "SecretKey": "your jwt secret key",
    "Issuer": "https://localhost:7001",
    "Audience": "https://localhost:7001",
    "TokenExpiryInMinutes": 600,
    "RefreshTokenExpiryInMinutes": 600
  },

  "FileUpload": {
    "RootPath": "uploads",
    "RequestPath": "/uploads"
  },

  "Email": {
    "FromAddress": "noreply@yourdomain.com",
    "FromName": "A Bit of Code - Development",
    "PickupDirectory": "C:/Dev/ABCD/maildrop"
  }
}