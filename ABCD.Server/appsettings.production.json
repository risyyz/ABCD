{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "ConnectionStrings": {
    "DefaultConnection": "YOUR_REAL_CONNECTION_STRING_HERE"
  },

  "Ai": {
    "ApiKey": "store in environment variables",
    "Model": "gpt-4o-mini"
  },

  "Admin": {
    "Email": "admin@admin.com"
  },

  "Crypto": {
    "PassPhrase": "a really long pass phrase - store in environment variables"
  },

  "AuthCookie": {
    "AccessTokenExpiryInMinutes": 240,
    "RefreshTokenExpiryInMinutes": 240
  },

  "Jwt": {
    "SecretKey": "your jwt secret key - store in environment variables",
    "Issuer": "your jwt issuer",
    "Audience": "your jwt audience",
    "ExpiryInMinutes": 30,
    "RefreshTokenExpiryInMinutes": 30
  },

  "FileUpload": {
    "RootPath": "uploads",
    "RequestPath": "/uploads"
  }
}